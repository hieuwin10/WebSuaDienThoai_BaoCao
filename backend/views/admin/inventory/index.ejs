<%- include('../../layouts/header') %>

<div class="glass animate-fade" style="padding: 2rem; border-radius: var(--radius-xl);">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h2 style="font-size: 1.5rem; font-weight: 700;">Kho linh kiện</h2>
            <p style="color: var(--text-muted); font-size: 0.875rem;">Quản lý linh kiện sửa chữa và tồn kho</p>
        </div>
        <button class="btn-premium" onclick="openModal()">
            <i class="fas fa-plus"></i> Thêm linh kiện
        </button>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Linh kiện</th>
                    <th>SKU</th>
                    <th>Số lượng tồn</th>
                    <th>Giá nhập/bán</th>
                    <th>Trạng thái</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody id="componentTable">
                <!-- Data loaded via JS -->
            </tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div id="componentModal" class="glass" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 2000; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
    <div class="glass" style="width: 100%; max-width: 450px; padding: 2.5rem; border-radius: var(--radius-xl);">
        <h2 id="modalTitle" style="margin-bottom: 1.5rem; font-weight: 700;">Thêm linh kiện</h2>
        <form id="componentForm">
            <input type="hidden" id="componentId">
            <div style="margin-bottom: 1.25rem;">
                <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Tên linh kiện</label>
                <input type="text" id="name" class="form-input-premium" required>
            </div>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem;">
                <div class="form-group">
                    <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">SKU</label>
                    <input type="text" id="sku" class="form-input-premium" required>
                </div>
                <div class="form-group">
                    <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Số lượng</label>
                    <input type="number" id="stock_quantity" class="form-input-premium" required value="0">
                </div>
            </div>
            <div style="margin-bottom: 2rem;">
                <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Giá (VNĐ)</label>
                <input type="number" id="price" class="form-input-premium" required>
            </div>
            <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                <button type="button" class="btn-premium" style="background: var(--bg-card); color: var(--text-main);" onclick="closeModal()">Hủy</button>
                <button type="submit" class="btn-premium">Lưu linh kiện</button>
            </div>
        </form>
    </div>
</div>

<script>
    async function loadData() {
        const res = await fetch('/api/v1/components');
        const data = await res.json();
        const tbody = document.getElementById('componentTable');
        
        tbody.innerHTML = data.map(c => {
            const isLow = c.stock_quantity < 5;
            return `
                <tr>
                    <td style="font-weight: 600;">${c.name}</td>
                    <td><code style="font-size: 0.75rem;">${c.sku}</code></td>
                    <td style="font-weight: 700; font-size: 1.1rem; ${isLow ? 'color: var(--danger);' : ''}">${c.stock_quantity}</td>
                    <td style="font-weight: 600;">${new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(c.price)}</td>
                    <td><span class="badge ${isLow ? 'badge-danger' : 'badge-success'}">${isLow ? 'Sắp hết' : 'Ổn định'}</span></td>
                    <td>
                        <button class="btn-premium" style="padding: 0.5rem; width: 32px; height: 32px;" onclick="editItem('${c._id}', '${c.name}', '${c.sku}', ${c.stock_quantity}, ${c.price})">
                            <i class="fas fa-edit" style="font-size: 0.8rem;"></i>
                        </button>
                    </td>
                </tr>
            `;
        }).join('') || '<tr><td colspan="6" style="text-align:center;">Kho trống</td></tr>';
    }

    function openModal() {
        document.getElementById('modalTitle').innerText = 'Thêm linh kiện';
        document.getElementById('componentId').value = '';
        document.getElementById('componentForm').reset();
        document.getElementById('componentModal').style.display = 'flex';
    }

    function editItem(id, name, sku, qty, price) {
        document.getElementById('modalTitle').innerText = 'Cập nhật linh kiện';
        document.getElementById('componentId').value = id;
        document.getElementById('name').value = name;
        document.getElementById('sku').value = sku;
        document.getElementById('stock_quantity').value = qty;
        document.getElementById('price').value = price;
        document.getElementById('componentModal').style.display = 'flex';
    }

    function closeModal() {
        document.getElementById('componentModal').style.display = 'none';
    }

    document.getElementById('componentForm').onsubmit = async (e) => {
        e.preventDefault();
        const id = document.getElementById('componentId').value;
        const data = {
            name: document.getElementById('name').value,
            sku: document.getElementById('sku').value,
            stock_quantity: Number(document.getElementById('stock_quantity').value),
            price: Number(document.getElementById('price').value)
        };
        const method = id ? 'PUT' : 'POST';
        const url = id ? `/api/v1/components/${id}` : '/api/v1/components';

        const res = await fetch(url, {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
        });
        if (res.ok) {
            closeModal();
            loadData();
        }
    };

    loadData();
</script>

<%- include('../../layouts/footer') %>
