<%- include('../layouts/header') %>

<div class="glass animate-fade" style="padding: 2rem; border-radius: var(--radius-xl);">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <div>
            <h2 style="font-size: 1.5rem; font-weight: 700;">Quản lý phiếu sửa chữa</h2>
            <p style="color: var(--text-muted); font-size: 0.875rem;">Theo dõi trạng thái tiếp nhận và xử lý thiết bị</p>
        </div>
        <button class="btn-premium" onclick="openCreateModal()">
            <i class="fas fa-plus"></i> Lập phiếu mới
        </button>
    </div>

    <div class="table-container">
        <table>
            <thead>
                <tr>
                    <th>Mã phiếu</th>
                    <th>Thiết bị / Khách hàng</th>
                    <th>Trạng thái</th>
                    <th>Tổng chi phí</th>
                    <th>Thao tác</th>
                </tr>
            </thead>
            <tbody id="ticketTable">
                <!-- Data loaded via JS -->
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Lập Phiếu -->
<div id="ticketModal" class="glass" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 2000; align-items: center; justify-content: center; backdrop-filter: blur(4px);">
    <div class="glass" style="width: 100%; max-width: 700px; padding: 2.5rem; border-radius: var(--radius-xl); max-height: 90vh; overflow-y: auto;">
        <h2 style="margin-bottom: 1.5rem; font-weight: 700;">Lập phiếu sửa chữa mới</h2>
        <form id="ticketForm">
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
                <div class="form-group">
                    <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Mã phiếu tự động</label>
                    <input type="text" id="ticket_code" class="form-input-premium" readonly value="REPAIR-${Date.now().toString().slice(-6)}">
                </div>
                <div class="form-group">
                    <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Thiết bị khách hàng</label>
                    <select id="device_id" class="form-input-premium" required>
                        <!-- Devices loaded via JS -->
                    </select>
                </div>
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Dịch vụ sửa chữa</label>
                <div id="services-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; padding: 1rem; background: rgba(255,255,255,0.02); border-radius: var(--radius-md); border: 1px solid var(--border);">
                    <!-- Services checkboxes -->
                </div>
            </div>

            <div style="margin-bottom: 1.5rem;">
                <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Linh kiện thay thế</label>
                <div id="components-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; padding: 1rem; background: rgba(255,255,255,0.02); border-radius: var(--radius-md); border: 1px solid var(--border);">
                    <!-- Components checkboxes -->
                </div>
            </div>

            <div style="margin-bottom: 2rem;">
                <label style="display: block; margin-bottom: 0.5rem; font-weight: 600;">Ghi chú tình trạng</label>
                <textarea id="note" class="form-input-premium" rows="2" placeholder="Ví dụ: Bể màn hình, không lên nguồn..."></textarea>
            </div>

            <div style="display: flex; gap: 1rem; justify-content: flex-end;">
                <button type="button" class="btn-premium" style="background: var(--bg-card); color: var(--text-main);" onclick="closeModal()">Hủy</button>
                <button type="submit" class="btn-premium">Xác nhận lập phiếu</button>
            </div>
        </form>
    </div>
</div>

<script>
    const getStatusBadge = (s) => ({
        'pending': 'badge-warning',
        'fixing': 'badge-info',
        'completed': 'badge-success',
        'canceled': 'badge-danger'
    }[s] || 'badge-secondary');
    
    const formatStatus = (s) => ({
        'pending': 'Chờ nhận',
        'fixing': 'Đang sửa',
        'completed': 'Hoàn thành',
        'canceled': 'Đã hủy'
    }[s] || s);

    async function loadTickets() {
        const res = await fetch('/api/v1/repair-tickets');
        const data = await res.json();
        const tbody = document.getElementById('ticketTable');
        
        tbody.innerHTML = data.map(t => `
            <tr>
                <td><code style="color: var(--primary-light); font-weight: 700;">#${t.ticket_code}</code></td>
                <td>
                    <div style="font-weight: 600;">${t.device_id?.brand || ''} ${t.device_id?.model_name || 'N/A'}</div>
                    <div style="font-size: 0.75rem; color: var(--text-muted);">IMEI: ${t.device_id?.imei || 'N/A'}</div>
                </td>
                <td>
                    <select class="form-input-premium" style="padding: 0.25rem 0.5rem; width: auto; font-size: 0.75rem;" onchange="updateStatus('${t._id}', this.value)">
                        <option value="pending" ${t.status === 'pending' ? 'selected' : ''}>Chờ nhận</option>
                        <option value="fixing" ${t.status === 'fixing' ? 'selected' : ''}>Đang sửa</option>
                        <option value="completed" ${t.status === 'completed' ? 'selected' : ''}>Hoàn thành</option>
                        <option value="canceled" ${t.status === 'canceled' ? 'selected' : ''}>Đã hủy</option>
                    </select>
                </td>
                <td style="font-weight: 700;">${new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(t.total_cost)}</td>
                <td>
                    <button class="btn-premium" style="padding: 0.5rem; width: 32px; height: 32px;" title="Chi tiết">
                        <i class="fas fa-eye" style="font-size: 0.8rem;"></i>
                    </button>
                </td>
            </tr>
        `).join('') || '<tr><td colspan="5" style="text-align:center;">Chưa có phiếu nào</td></tr>';
    }

    async function openCreateModal() {
        const [dRes, sRes, cRes] = await Promise.all([
            fetch('/api/v1/devices'),
            fetch('/api/v1/services'),
            fetch('/api/v1/components')
        ]);
        const devices = await dRes.json();
        const services = await sRes.json();
        const components = await cRes.json();

        document.getElementById('device_id').innerHTML = devices.map(d => `<option value="${d._id}">${d.brand} ${d.model_name} (${d.imei})</option>`).join('');
        
        document.getElementById('services-grid').innerHTML = services.map(s => `
            <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; cursor: pointer;">
                <input type="checkbox" name="services" value="${s._id}" data-price="${s.base_price}"> ${s.name}
            </label>
        `).join('');

        document.getElementById('components-grid').innerHTML = components.map(c => `
            <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; cursor: pointer; ${c.stock_quantity <= 0 ? 'opacity: 0.5;' : ''}">
                <input type="checkbox" name="components" value="${c._id}" data-price="${c.price}" ${c.stock_quantity <= 0 ? 'disabled' : ''}> ${c.name} (${c.stock_quantity})
            </label>
        `).join('');

        document.getElementById('ticketModal').style.display = 'flex';
    }

    function closeModal() {
        document.getElementById('ticketModal').style.display = 'none';
    }

    document.getElementById('ticketForm').onsubmit = async (e) => {
        e.preventDefault();
        
        const serviceIds = Array.from(document.querySelectorAll('input[name="services"]:checked')).map(el => el.value);
        const componentCheckboxes = Array.from(document.querySelectorAll('input[name="components"]:checked'));
        const componentIds = componentCheckboxes.map(el => ({
            component_id: el.value,
            quantity: 1
        }));

        // Calculate total cost
        let total = 0;
        Array.from(document.querySelectorAll('input[name="services"]:checked')).forEach(el => total += Number(el.dataset.price));
        componentCheckboxes.forEach(el => total += Number(el.dataset.price));

        const body = {
            ticket_code: document.getElementById('ticket_code').value,
            device_id: document.getElementById('device_id').value,
            services: serviceIds,
            components_used: componentIds,
            total_cost: total,
            note: document.getElementById('note').value
        };

        const res = await fetch('/api/v1/repair-tickets', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });

        if (res.ok) {
            closeModal();
            loadTickets();
        } else {
            const err = await res.json();
            alert(err.message);
        }
    };

    async function updateStatus(id, status) {
        try {
            const res = await fetch(`/api/v1/repair-tickets/${id}/status`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });
            if (res.ok) loadTickets();
        } catch (err) { console.error(err); }
    }

    loadTickets();
</script>

<%- include('../layouts/footer') %>
