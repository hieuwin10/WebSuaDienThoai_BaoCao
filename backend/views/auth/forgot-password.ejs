<%- include('../layouts/header') %>

<div class="auth-wrapper">
  <div class="auth-card">
    <div class="auth-header">
      <h1>Quên mật khẩu</h1>
      <p>Nhập email của bạn để nhận link khôi phục</p>
    </div>

    <div id="alert-container"></div>

    <form id="forgot-form">
      <div class="form-group">
        <label class="form-label">Email tài khoản</label>
        <input type="email" id="email" class="form-control" placeholder="name@example.com" required>
      </div>
      <button type="submit" class="btn btn-primary" id="btn-submit" style="margin-top: 1rem;">Gửi yêu cầu</button>
    </form>

    <div class="auth-footer">
      Nhớ lại mật khẩu? <a href="/auth/login">Quay lại đăng nhập</a>
    </div>
  </div>
</div>

<script>
  const forgotForm = document.getElementById('forgot-form');
  const alertContainer = document.getElementById('alert-container');
  const btnSubmit = document.getElementById('btn-submit');

  forgotForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = document.getElementById('email').value;

    btnSubmit.disabled = true;
    btnSubmit.innerText = 'Đang gửi...';
    alertContainer.innerHTML = '';

    try {
      const res = await fetch('/api/v1/auth/forgotpassword', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });

      const data = await res.json();

      alertContainer.innerHTML = `<div class="alert alert-success">${data.message}</div>`;
      btnSubmit.disabled = false;
      btnSubmit.innerText = 'Gửi lại';
      
    } catch (err) {
      alertContainer.innerHTML = `<div class="alert alert-error">Lỗi kết nối server</div>`;
      btnSubmit.disabled = false;
      btnSubmit.innerText = 'Gửi yêu cầu';
    }
  });
</script>

<%- include('../layouts/footer') %>
