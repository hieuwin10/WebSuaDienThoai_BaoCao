<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Đăng nhập | PhoneRepair Pro</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            display: flex;
            align-items: center;
            justify-content: center;
            background: radial-gradient(circle at top right, #1e293b, #0f172a);
        }
        .auth-container {
            width: 100%;
            max-width: 420px;
            padding: 2rem;
        }
        .auth-logo {
            text-align: center;
            margin-bottom: 2.5rem;
        }
        .auth-logo i {
            font-size: 3rem;
            margin-bottom: 1rem;
            color: var(--primary-light);
        }
        .auth-logo h1 {
            font-size: 1.75rem;
            font-weight: 800;
        }
    </style>
</head>
<body class="animate-fade">
    <div class="auth-container">
        <div class="auth-logo">
            <i class="fas fa-tools"></i>
            <h1>PhoneRepair <span style="color: var(--primary-light);">Pro</span></h1>
            <p style="color: var(--text-muted);">Hệ thống quản lý thông minh</p>
        </div>

        <div class="glass" style="padding: 2.5rem; border-radius: var(--radius-xl); box-shadow: var(--shadow-xl);">
            <h2 style="margin-bottom: 1.5rem; font-weight: 700;">Đăng nhập</h2>
            
            <div id="alert" style="display: none;" class="alert alert-error"></div>

            <form id="loginForm">
                <div style="margin-bottom: 1.25rem;">
                    <label style="display: block; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem;">Tên đăng nhập</label>
                    <input type="text" name="username" class="form-input-premium" placeholder="Nhập username" required>
                </div>
                <div style="margin-bottom: 1.5rem;">
                    <label style="display: block; font-size: 0.875rem; font-weight: 500; margin-bottom: 0.5rem;">Mật khẩu</label>
                    <input type="password" name="password" class="form-input-premium" placeholder="••••••••" required>
                </div>
                <button type="submit" class="btn-premium" style="width: 100%; justify-content: center;">
                    Đăng nhập <i class="fas fa-arrow-right"></i>
                </button>
            </form>

            <div style="margin-top: 2rem; text-align: center; font-size: 0.875rem; color: var(--text-muted);">
                Chưa có tài khoản? <a href="/auth/register" style="color: var(--primary-light); text-decoration: none; font-weight: 600;">Đăng ký ngay</a>
            </div>
        </div>
    </div>

    <script>
        document.getElementById('loginForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(e.target);
            const data = Object.fromEntries(formData.entries());
            const alert = document.getElementById('alert');

            try {
                const response = await fetch('/api/v1/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await response.json();

                if (response.ok) {
                    window.location.href = '/';
                } else {
                    alert.style.display = 'block';
                    alert.textContent = result.message || 'Đăng nhập thất bại';
                }
            } catch (err) {
                alert.style.display = 'block';
                alert.textContent = 'Lỗi kết nối máy chủ';
            }
        });
    </script>
</body>
</html>
