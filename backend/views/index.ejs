<%- include('layouts/header') %>

<div id="stats-container" class="stats-grid animate-fade">
    <!-- Stat cards will be loaded via AJAX for real-time feel or EJS if preferred. -->
</div>

<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 1.5rem;">
    <div class="glass animate-fade" style="padding: 1.5rem; border-radius: var(--radius-lg);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h2 style="font-size: 1.25rem; font-weight: 700;">Phieu sua chua gan day</h2>
            <a href="/admin/repair-tickets" style="color: var(--primary-light); text-decoration: none; font-size: 0.875rem;">Xem tat ca</a>
        </div>

        <div class="table-container">
            <table>
                <thead>
                    <tr>
                        <th>Ma phieu</th>
                        <th>Thiet bi</th>
                        <th>Trang thai</th>
                        <th>Tong tien</th>
                    </tr>
                </thead>
                <tbody id="recent-tickets-body">
                    <tr><td colspan="4">Dang tai...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <div class="glass animate-fade" style="padding: 1.5rem; border-radius: var(--radius-lg); height: fit-content;">
        <h2 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 1.5rem;">Phan bo trang thai</h2>
        <div id="status-distribution" style="display: flex; flex-direction: column; gap: 1rem;"></div>
    </div>
</div>

<script>
    const formatCurrency = (val) => new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(val);
    const getStatusBadge = (s) => ({
        'pending': 'badge-warning',
        'fixing': 'badge-info',
        'completed': 'badge-success',
        'canceled': 'badge-danger'
    }[s] || 'badge-secondary');

    const formatStatus = (s) => ({
        'pending': 'Cho nhan',
        'fixing': 'Dang sua',
        'completed': 'Hoan thanh',
        'canceled': 'Da huy'
    }[s] || s);

    async function loadDashboard() {
        const res = await fetch('/api/v1/dashboard/stats');
        const data = await res.json();

        document.getElementById('stats-container').innerHTML = `
            <div class="glass stat-card">
                <div class="stat-icon" style="background: rgba(99, 102, 241, 0.2); color: var(--primary-light);"><i class="fas fa-coins"></i></div>
                <div class="stat-info"><h3>Doanh thu</h3><div class="value">${formatCurrency(data.revenue.total)}</div></div>
            </div>
            <div class="glass stat-card">
                <div class="stat-icon" style="background: rgba(16, 185, 129, 0.2); color: var(--success);"><i class="fas fa-file-circle-check"></i></div>
                <div class="stat-info"><h3>Hoan tat</h3><div class="value">${data.revenue.count}</div></div>
            </div>
            <div class="glass stat-card">
                <div class="stat-icon" style="background: rgba(14, 165, 233, 0.2); color: var(--info);"><i class="fas fa-microchip"></i></div>
                <div class="stat-info"><h3>Linh kien</h3><div class="value">${data.counts.components}</div></div>
            </div>
            <div class="glass stat-card">
                <div class="stat-icon" style="background: rgba(244, 63, 94, 0.2); color: var(--accent);"><i class="fas fa-users-gear"></i></div>
                <div class="stat-info"><h3>Nhan su</h3><div class="value">${data.counts.staff}</div></div>
            </div>
        `;

        document.getElementById('recent-tickets-body').innerHTML = data.recentTickets.map(t => `
            <tr>
                <td style="font-weight: 600; color: var(--primary-light);">#${t.ticket_code}</td>
                <td>${t.device_id?.brand || ''} ${t.device_id?.model_name || 'N/A'}</td>
                <td><span class="badge ${getStatusBadge(t.status)}">${formatStatus(t.status)}</span></td>
                <td>${formatCurrency(t.total_cost)}</td>
            </tr>
        `).join('') || '<tr><td colspan="4">Chua co du lieu</td></tr>';

        document.getElementById('status-distribution').innerHTML = data.statusStats.map(s => `
            <div>
                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem; font-size: 0.875rem;">
                    <span>${formatStatus(s._id)}</span>
                    <span style="font-weight: 600;">${s.count}</span>
                </div>
                <div style="height: 6px; background: rgba(255,255,255,0.05); border-radius: 3px; overflow: hidden;">
                    <div style="height: 100%; width: ${(s.count / (data.revenue.count || 1) * 100).toFixed(0)}%; background: var(--primary-light);"></div>
                </div>
            </div>
        `).join('');
    }

    loadDashboard();
</script>

<%- include('layouts/footer') %>
