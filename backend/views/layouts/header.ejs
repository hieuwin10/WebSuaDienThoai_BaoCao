<%
function getStatusBadge(status) {
    switch(status) {
        case 'pending': return 'badge-warning';
        case 'fixing': return 'badge-info';
        case 'completed': return 'badge-success';
        case 'canceled': return 'badge-danger';
        default: return 'badge-secondary';
    }
}

function formatStatus(status) {
    const statuses = {
        'pending': 'Chờ nhận',
        'fixing': 'Đang sửa',
        'completed': 'Hoàn thành',
        'canceled': 'Đã hủy'
    };
    return statuses[status] || status;
}

function formatCurrency(amount) {
    return new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(amount);
}
%>
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PhoneRepair Pro | Hệ thống quản lý thông minh</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>
    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-logo">
                <i class="fas fa-tools"></i>
                <span>PR-PRO</span>
            </div>
            
            <nav class="sidebar-menu">
                <a href="/" class="menu-item <%= typeof active === 'undefined' || active === 'dashboard' ? 'active' : '' %>">
                    <i class="fas fa-chart-line"></i>
                    <span>Tổng quan</span>
                </a>
                <a href="/admin/repair-tickets" class="menu-item <%= typeof active !== 'undefined' && active === 'tickets' ? 'active' : '' %>">
                    <i class="fas fa-file-invoice"></i>
                    <span>Phiếu sửa chữa</span>
                </a>
                <a href="/admin/warranty" class="menu-item <%= typeof active !== 'undefined' && active === 'warranty' ? 'active' : '' %>">
                    <i class="fas fa-shield-halved"></i>
                    <span>Bảo hành</span>
                </a>
                <a href="/admin/inventory" class="menu-item <%= typeof active !== 'undefined' && active === 'inventory' ? 'active' : '' %>">
                    <i class="fas fa-boxes-stacked"></i>
                    <span>Kho linh kiện</span>
                </a>
                <div style="margin-top: auto;"></div>
                <hr style="border: none; border-top: 1px solid var(--border-light); margin: 1rem 0;">
                <a href="/profile" class="menu-item <%= typeof active !== 'undefined' && active === 'profile' ? 'active' : '' %>">
                    <i class="fas fa-user-circle"></i>
                    <span>Tài khoản</span>
                </a>
                <a href="#" onclick="logout()" class="menu-item text-danger">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Đăng xuất</span>
                </a>
            </nav>
        </aside>

        <!-- Main Content Wrapper -->
        <main class="main-content">
            <header style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                <div>
                    <h1 style="font-size: 2rem; font-weight: 700;"><%= title || 'Dashboard' %></h1>
                    <p style="color: var(--text-muted);"><%= typeof subtitle !== 'undefined' ? subtitle : 'Chào mừng trở lại hệ thống' %></p>
                </div>
                
                <div class="glass" style="padding: 0.5rem 1rem; border-radius: 999px; display: flex; align-items: center; gap: 0.75rem;">
                    <img src="<%= user && user.avatarUrl ? user.avatarUrl : '/images/default-avatar.png' %>" style="width: 32px; height: 32px; border-radius: 50%; object-fit: cover;">
                    <span style="font-weight: 600;"><%= user ? (user.fullName || user.username) : 'Guest' %></span>
                </div>
            </header>

<script>
    async function logout() {
        if(!confirm('Đăng xuất khỏi hệ thống?')) return;
        const res = await fetch('/api/v1/auth/logout', { method: 'POST' });
        if(res.ok) window.location.href = '/auth/login';
    }
</script>
