<%- include('layouts/header') %>

<div class="glass animate-fade" style="padding: 2rem; border-radius: var(--radius-xl); max-width: 800px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 2.5rem; position: relative;">
        <!-- Cover Photo -->
        <div style="height: 200px; background: linear-gradient(135deg, var(--primary), var(--secondary)); border-radius: var(--radius-lg); margin-bottom: -50px; opacity: 0.3;"></div>
        
        <!-- Avatar -->
        <div style="position: relative; display: inline-block;">
            <img src="<%= user.avatarUrl || '/images/default-avatar.png' %>" id="profile-avatar" style="width: 120px; height: 120px; border-radius: 50%; border: 4px solid var(--bg-main); object-fit: cover; box-shadow: var(--shadow-xl);">
            <label for="avatar-input" style="position: absolute; bottom: 0; right: 0; background: var(--primary); color: white; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; border: 2px solid var(--bg-main);">
                <i class="fas fa-camera" style="font-size: 0.8rem;"></i>
            </label>
            <input type="file" id="avatar-input" style="display: none;" onchange="uploadImage('avatar')">
        </div>
        
        <h2 style="margin-top: 1rem; font-size: 1.5rem; font-weight: 700;"><%= user.fullName || user.username %></h2>
        <p style="color: var(--text-muted);"><%= user.role?.name || 'Thành viên' %></p>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
        <div class="form-group">
            <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1.25rem; color: var(--primary-light);">Thông tin cơ bản</h3>
            <div style="margin-bottom: 1rem;">
                <label style="display: block; font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.25rem;">Họ và tên</label>
                <div style="font-weight: 500;"><%= user.fullName || 'Chưa cập nhật' %></div>
            </div>
            <div style="margin-bottom: 1rem;">
                <label style="display: block; font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.25rem;">Email</label>
                <div style="font-weight: 500;"><%= user.email %></div>
            </div>
            <div style="margin-bottom: 1rem;">
                <label style="display: block; font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.25rem;">Tên đăng nhập</label>
                <div style="font-weight: 500;"><%= user.username %></div>
            </div>
        </div>

        <div class="form-group">
            <h3 style="font-size: 1rem; font-weight: 600; margin-bottom: 1.25rem; color: var(--primary-light);">Bảo mật</h3>
            <button class="btn-premium" style="width: 100%; margin-bottom: 1rem;" onclick="openPasswordModal()">
                <i class="fas fa-key"></i> Đổi mật khẩu
            </button>
            <div class="glass" style="padding: 1rem; border-radius: var(--radius-md); font-size: 0.875rem;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                    <span>Số lần đăng nhập</span>
                    <span style="font-weight: 600;"><%= user.loginCount %></span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span>Tham gia từ</span>
                    <span style="font-weight: 600;"><%= new Date(user.createdAt).toLocaleDateString('vi-VN') %></span>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    async function uploadImage(type) {
        const file = document.getElementById('avatar-input').files[0];
        if (!file) return;

        const formData = new FormData();
        formData.append('image', file);

        try {
            const res = await fetch('/api/v1/profiles/upload-avatar', {
                method: 'POST',
                body: formData
            });
            if (res.ok) {
                const data = await res.json();
                document.getElementById('profile-avatar').src = data.url;
            }
        } catch (err) { console.error(err); }
    }
</script>

<%- include('layouts/footer') %>
